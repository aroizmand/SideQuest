# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stream Chat
EXPO_PUBLIC_STREAM_API_KEY=your-stream-api-key

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# The following are server-side only — used in Supabase Edge Functions, never in the mobile app.
# Add these in your Supabase project dashboard under Settings > Edge Functions > Secrets.
# OPENAI_API_KEY=sk-...
# STREAM_API_SECRET=your-stream-api-secret
# STRIPE_SECRET_KEY=sk_test_...
# EXPO_PUSH_ACCESS_TOKEN=your-expo-push-token
